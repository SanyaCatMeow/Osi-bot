# ============================================================
#  OSINT Bot — Configuration Template
#  Copy this file to config.env and fill in your values
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── OPTIONAL (free tier) ────────────────────────────────────

# VirusTotal — free 4 req/min: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AbuseIPDB — free 1000/day: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# Numverify — free 100/month: https://numverify.com/product
NUMVERIFY_API_KEY=

# Google Safe Browsing — free: https://developers.google.com/safe-browsing
GOOGLE_SAFE_BROWSING_KEY=

# HaveIBeenPwned — $3.5/month: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=
